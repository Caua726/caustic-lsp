{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Caustic",
  "scopeName": "source.caustic",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#characters" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#function-definition" },
    { "include": "#struct-definition" },
    { "include": "#enum-definition" },
    { "include": "#impl-block" },
    { "include": "#use-statement" },
    { "include": "#function-call" },
    { "include": "#module-access" },
    { "include": "#operators" },
    { "include": "#punctuation" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.caustic",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.caustic",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.caustic",
              "match": "\\\\[nrt\\\\\"0]"
            }
          ]
        }
      ]
    },
    "characters": {
      "patterns": [
        {
          "name": "string.quoted.single.caustic",
          "match": "'(\\\\[nrt\\\\\"0]|[^'])'"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.caustic",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.hex.caustic",
          "match": "\\b0[xX][0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.integer.caustic",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.caustic",
          "match": "\\b(if|else|while|for|do|break|continue|return|match|case)\\b"
        },
        {
          "name": "keyword.declaration.caustic",
          "match": "\\b(fn|let|struct|enum|type|impl|extern|use)\\b"
        },
        {
          "name": "keyword.other.caustic",
          "match": "\\b(is|as|with|only|gen|defer|section)\\b"
        },
        {
          "name": "keyword.operator.caustic",
          "match": "\\b(cast|sizeof|syscall|asm|fn_ptr|call)\\b"
        },
        {
          "name": "support.function.builtin.caustic",
          "match": "\\b(atomic_load|atomic_store|atomic_add|atomic_xchg|atomic_cas|__builtin_sqrt|__builtin_va_start)\\b"
        },
        {
          "name": "constant.language.builtin.caustic",
          "match": "\\b(__target_is_linux|__target_is_windows|__target_is_caustic|__compat_mode|__compile_error|__allow_unsupported)\\b"
        },
        {
          "name": "storage.modifier.caustic",
          "match": "\\b(mut|imut)\\b"
        },
        {
          "name": "constant.language.boolean.caustic",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.primitive.caustic",
          "match": "\\b(i8|i16|i32|i64|u8|u16|u32|u64|f32|f64|bool|char|string|void)\\b"
        }
      ]
    },
    "function-definition": {
      "patterns": [
        {
          "match": "\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*(gen)\\b",
          "captures": {
            "1": { "name": "keyword.declaration.caustic" },
            "2": { "name": "entity.name.function.caustic" },
            "3": { "name": "keyword.other.caustic" }
          }
        },
        {
          "match": "\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.caustic" },
            "2": { "name": "entity.name.function.caustic" }
          }
        }
      ]
    },
    "struct-definition": {
      "patterns": [
        {
          "match": "\\b(struct)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.caustic" },
            "2": { "name": "entity.name.type.struct.caustic" }
          }
        }
      ]
    },
    "enum-definition": {
      "patterns": [
        {
          "match": "\\b(enum)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.caustic" },
            "2": { "name": "entity.name.type.enum.caustic" }
          }
        }
      ]
    },
    "impl-block": {
      "patterns": [
        {
          "match": "\\b(impl)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.caustic" },
            "2": { "name": "entity.name.type.caustic" }
          }
        }
      ]
    },
    "use-statement": {
      "patterns": [
        {
          "match": "\\b(use)\\s+(\"[^\"]*\")\\s+(only)\\b",
          "captures": {
            "1": { "name": "keyword.declaration.caustic" },
            "2": { "name": "string.quoted.double.caustic" },
            "3": { "name": "keyword.other.caustic" }
          }
        },
        {
          "match": "\\b(use)\\s+(\"[^\"]*\")\\s+(as)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.caustic" },
            "2": { "name": "string.quoted.double.caustic" },
            "3": { "name": "keyword.other.caustic" },
            "4": { "name": "entity.name.namespace.caustic" }
          }
        }
      ]
    },
    "function-call": {
      "patterns": [
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
          "captures": {
            "1": { "name": "entity.name.function.call.caustic" }
          }
        }
      ]
    },
    "module-access": {
      "patterns": [
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\.([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
          "captures": {
            "1": { "name": "entity.name.namespace.caustic" },
            "2": { "name": "entity.name.function.call.caustic" }
          }
        },
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\.([A-Z][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "entity.name.namespace.caustic" },
            "2": { "name": "entity.name.type.caustic" }
          }
        },
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\.([A-Z_][A-Z0-9_]*)",
          "captures": {
            "1": { "name": "entity.name.namespace.caustic" },
            "2": { "name": "constant.other.caustic" }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.caustic",
          "match": "(\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^=|<<=|>>=|=)"
        },
        {
          "name": "keyword.operator.comparison.caustic",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.logical.caustic",
          "match": "(&&|\\|\\||!)"
        },
        {
          "name": "keyword.operator.bitwise.caustic",
          "match": "(<<|>>|&|\\||\\^|~)"
        },
        {
          "name": "keyword.operator.arithmetic.caustic",
          "match": "(\\+|-|\\*|/|%)"
        },
        {
          "name": "keyword.operator.pointer.caustic",
          "match": "\\*(?=[a-zA-Z])"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.caustic",
          "match": "[;,]"
        },
        {
          "name": "punctuation.accessor.caustic",
          "match": "\\."
        },
        {
          "name": "punctuation.bracket.caustic",
          "match": "[{}()\\[\\]]"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.caustic",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
